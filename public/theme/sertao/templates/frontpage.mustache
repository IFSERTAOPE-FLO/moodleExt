    </div>
  </div>
</nav>

<!-- ================================================
    HERO
================================================ -->
<section id="inicio" class="hero-section">
  <div class="container" style="position:relative;z-index:1">
    <div class="row align-items-center">

      <!-- left -->
      <div class="col-lg-6">
        <h1>Transforme seu <span class="accent">Futuro</span><br>com Educação!</h1>
        <p class="hero-subtitle">
          A melhor plataforma de ensino no Sertão. Desenvolvida pelo
          <b>IFSERTÃO-PE Campus Floresta</b>.
        </p>
        <div class="hero-btns">
          <a href="#cursos" class="btn-accent">Começar Agora &rarr;</a>
          <a href="#sobre" class="btn-outline-hero">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 9h-2V7h2m0 10h-2v-6h2m-1-9A10 10 0 0 0 2 12a10 10 0 0 0 10 10 10 10 0 0 0 10-10A10 10 0 0 0 12 2z"/></svg>
            Saiba Mais
          </a>
        </div>
      </div>

      <!-- right -->
      <div class="col-lg-6 mt-5 mt-lg-0">
        <div class="hero-visual">
          <img src="{{{ hero_image_url }}}" alt="Campus IFSERTÃO-PE Floresta" class="hero-campus-img">
          <div class="hero-floating-card">
            <img src="{{{ logo_url }}}" alt="Sertão Conecta">
            <p>Conhecimento que conecta, educação que <span>transforma.</span></p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

