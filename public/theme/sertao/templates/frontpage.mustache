<script>
document.addEventListener('DOMContentLoaded', function () {
  // navbar scroll pill
  var navbar = document.querySelector('.landing-navbar');
  if (navbar) {
    var onScroll = function () {
      navbar.classList.toggle('scrolled', window.scrollY > 28);
    };
    onScroll();
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () { onScroll(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
  }

  // animate progress bars on scroll
  var bars = document.querySelectorAll('.progress-fill');
  if (bars.length && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var bar = entry.target;
          var target = bar.getAttribute('aria-valuenow') || '0';
          bar.style.width = '0%';
          setTimeout(function () { bar.style.width = target + '%'; }, 120);
          observer.unobserve(bar);
        }
      });
    }, { threshold: 0.3 });
    bars.forEach(function (b) { observer.observe(b); });
  }

  // active nav link on scroll
  var sections = document.querySelectorAll('section[id], footer[id]');
  var navLinks = document.querySelectorAll('.landing-navbar .nav-link');
  window.addEventListener('scroll', function () {
    var scrollY = window.scrollY + 120;
    sections.forEach(function (sec) {
      if (sec.offsetTop <= scrollY && sec.offsetTop + sec.offsetHeight > scrollY) {
        navLinks.forEach(function (link) {
          link.classList.remove('active');
          if (link.getAttribute('href') === '#' + sec.id) link.classList.add('active');
        });
      }
    });
  }, { passive: true });
});
</script>

