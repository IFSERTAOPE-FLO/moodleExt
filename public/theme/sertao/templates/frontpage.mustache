          <a href="#" class="course-link">Ver curso &rarr;</a>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="course-card">
          <div class="course-icon">
            <svg viewBox="0 0 24 24" fill="#fff"><path d="M17 8C8 10 5.9 16.17 3.82 21H5.71c.51-1.2 1.06-2.38 1.77-3.38C9.19 20.4 11.5 21 14 21c5.52 0 10-4.48 10-10 0-1.1-.18-2.16-.51-3.15C22.31 7.28 20 8 17 8z"/></svg>
