      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="scNav">
      <ul class="navbar-nav mx-auto gap-1">
        <li class="nav-item"><a class="nav-link active" href="#inicio">Início</a></li>
