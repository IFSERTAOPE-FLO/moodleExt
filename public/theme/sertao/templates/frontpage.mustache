<!-- ================================================
     GAMIFICAÇÃO
     ================================================ -->
<section class="gamification-section">
  <div class="container">
    <h2 class="section-title">Introdução à <span class="accent">Gamificação</span></h2>
    <div class="section-underline" style="background:var(--sc-yellow)"></div>

    <div class="row g-4 mt-2">

      <div class="col-md-4">
        <div class="game-card">
          <div class="game-card-label">
            <svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6h-6z"/></svg>
            Progresso Geral
          </div>
          <div class="progress-track">
            <div class="progress-fill" style="width:72%" aria-valuenow="72"></div>
