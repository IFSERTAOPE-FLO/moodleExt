      <a href="#">Ver todos os cursos &rarr;</a>
    </div>

    <div class="row g-4">
      {{#courses}}
      <div class="col-sm-6 col-xl-3">
        <div class="course-card">
          <div class="course-icon">
            <svg viewBox="0 0 24 24" fill="#fff"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .65.73.45.75.45C2.4 20.45 4.05 20 5.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.65 0 .5-.6.5-.65V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
          </div>
          <h5>{{title}}</h5>
          <p>{{summary}}</p>
          <a href="{{url}}" class="course-link">Ver curso &rarr;</a>
        </div>
      </div>
      {{/courses}}
      {{^courses}}
      <!-- placeholder cards when no dynamic data -->
      <div class="col-sm-6 col-xl-3">
        <div class="course-card">
          <div class="course-icon">
            <svg viewBox="0 0 24 24" fill="#fff"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
