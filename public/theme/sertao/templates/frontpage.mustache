{{!
    Landing Page template for Sertão Conecta.
}}
{{> theme_boost/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper" class="d-print-block">

    {{{ output.standard_top_of_body_html }}}
    <style>
        :root {
            --sertao-dark-green: #0B5B33;
            --sertao-light-green: #69a531;
            --sertao-yellow: #F2A900;
            --sertao-darker-green: #074223;
        }
        .landing-navbar {
            background: var(--sertao-dark-green) !important;
            box-shadow: 0 4px 15px rgba(0,0,0,.15);
            padding: 14px 0;
            transition: background .35s ease, box-shadow .35s ease, padding .35s ease;
            z-index: 1050;
        }
        .landing-navbar .navbar-brand {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: .2px;
        }
        .landing-navbar .container {
            transition: background .35s ease, box-shadow .35s ease, border-radius .35s ease, padding .35s ease;
        }
        .landing-navbar.scrolled {
            background: transparent !important;
            box-shadow: none;
            padding: 14px 0;
        }
        .landing-navbar.scrolled .container {
            background: rgba(7,66,35,.92);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 999px;
            backdrop-filter: blur(8px);
            max-width: 1120px;
            padding: 10px 18px;
            box-shadow: 0 14px 34px rgba(0,0,0,.24);
        }
        .landing-navbar .navbar-brand img {
            width: 72px;
            height: 72px;
            object-fit: contain;
        }
        .hero-section {
            background: linear-gradient(135deg, var(--sertao-dark-green) 0%, var(--sertao-darker-green) 100%);
            min-height: 92vh;
            padding-top: 140px !important;
            padding-bottom: 80px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 30%, rgba(255,255,255,.08), transparent 60%);
            pointer-events: none;
        }
        .hero-section h1 span {
            color: var(--sertao-yellow);
        }
        .hero-institutional-img {
            width: 100%;
            max-width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,.25);
            box-shadow: 0 10px 28px rgba(0,0,0,.2);
            display: block;
        }
        .about-visual-card {
            background: linear-gradient(160deg, #ffffff 0%, #f1f8f3 100%);
            border: 1px solid rgba(11,91,51,.12);
            border-radius: 16px;
            padding: 1.2rem;
            overflow: hidden;
        }
        .about-visual-card img {
            width: 100%;
            max-width: 100%;
            max-height: 280px;
            object-fit: contain;
            border-radius: 12px;
            display: block;
        }
        .hero-btns {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }
        .course-meta .badge {
            border-radius: 10px;
            font-size: .7rem;
        }
        .progress-bar {
            transition: width 1.2s ease-in-out;
        }
        @media (max-width: 768px) {
            .hero-section {
                padding-top: 120px !important;
                text-align: center;
            }
            .hero-section h1 {
                font-size: 2rem;
            }
            .hero-btns {
                flex-direction: column;
            }
            .hero-btns a {
                width: 100%;
            }
            .landing-navbar.scrolled .container {
                border-radius: 16px;
            }
            .landing-navbar .navbar-brand {
                font-size: 1.4rem;
            }
            .landing-navbar .navbar-brand img {
                width: 52px;
                height: 52px;
            }
        }
    </style>

    <!-- Navbar - barra de navegação -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top landing-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="#">
                <img src="{{{ logo_url }}}" alt="Logo Sertão Conecta">
                <span class="ms-2 fw-bold">SERTÃO CONECTA</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Alternar menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="#inicio">Início</a></li>
                    <li class="nav-item"><a class="nav-link" href="#cursos">Cursos</a></li>
                    <li class="nav-item"><a class="nav-link" href="#trilhas">Trilhas</a></li>
                    <li class="nav-item"><a class="nav-link" href="#sobre">Sobre</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <a href="{{{ login_url }}}" class="btn btn-outline-light me-3">Login</a>
                    <a href="#cursos" class="btn btn-primary">Começar Agora</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section - Seção inicial -->
    <section id="inicio" class="hero-section d-flex align-items-center">
        <div class="hero-overlay"></div>
        <div class="container position-relative">
            <div class="row align-items-center">
                <div class="col-lg-7 text-white">
                    <h1 class="display-4 fw-bold mb-4">
                        Transforme seu <span>Futuro</span> com Educação!
                    </h1>
                    <p class="lead mb-5">
                        A melhor plataforma de ensino no Sertão. Desenvolvida pelo
                        <b>IFSERTÃO-PE Campus Floresta</b>.
                    </p>
                    <div class="hero-btns mb-5">
                        <a href="#cursos" class="btn btn-lg btn-accent px-5 me-3">Começar Agora</a>
                        <a href="#sobre" class="btn btn-lg btn-outline-light px-5">Saiba Mais</a>
                    </div>
                </div>
                
                
                <!-- Aqui vai ficar as imagens institucional -->
                <div class="col-lg-5">
                    <div class="hero-image-container p-4 bg-white-10 rounded text-center">
                        <img src="{{{ hero_image_url }}}" alt="Imagem institucional do Sertão Conecta com identidade visual do projeto" class="hero-institutional-img mb-4" loading="lazy" decoding="async">
                        <div class="row text-white">
                            <div class="col-4">
                                <h4 class="fw-bold mb-0">5.000+</h4>
                                <small>Alunos</small>
                            </div>
                            <div class="col-4">
                                <h4 class="fw-bold mb-0">150+</h4>
                                <small>Cursos</small>
                            </div>
                            <div class="col-4">
                                <h4 class="fw-bold mb-0">1000+</h4>
                                <small>Certificados</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section - Seção de Sobre -->
    <section id="sobre" class="about-section py-5 bg-white">
        <div class="container mt-4">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0 text-center text-lg-start">
                    <h2 class="fw-bold section-title mb-4">Sobre o Projeto</h2>
                    <p class="lead text-muted mb-4 mt-3">Nossa Missão e Impacto no Sertão.</p>
                    <div class="about-text-placeholder text-start">
                        <p class="about-highlight mb-3">
                            O Sertão Conecta integra tecnologia, educação e inclusão digital para ampliar oportunidades de aprendizagem no território do Sertão.
                        </p>
                        <p class="mb-0 text-muted">
                            A proposta é oferecer trilhas práticas, linguagem acessível e progressão gamificada para manter o aluno engajado até a conclusão.
                        </p>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="about-visual-card shadow-sm">
                        <img src="{{{ about_image_url }}}" alt="Marca oficial do Sertão Conecta" loading="lazy" decoding="async">
                    </div>
                </div>
            </div>
        </div>
