                <div class="col-md-4 mb-3">
                    <h2 class="fw-bold" style="color: var(--sertao-light-green);">10+</h2>
                    <p class="fw-bold text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.85rem;">Cursos Disponíveis</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h2 class="fw-bold" style="color: var(--sertao-yellow);">100+</h2>
