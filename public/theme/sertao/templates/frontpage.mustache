      <div class="col-sm-6 col-xl-3">
        <div class="course-card">
          <div class="course-icon">
            <svg viewBox="0 0 24 24" fill="#fff"><path d="M20 6h-2.18c.07-.44.18-.87.18-1.33C18 2.53 15.48 0 12.33 0c-1.7 0-3.2.72-4.33 1.83L6 4 3.99 2C3.53.79 2.35 0 1 0v2c.66 0 1.22.42 1.43 1L5 8.7V21c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2v-2h1c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/></svg>
